<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- SCHEDULE_EXACT_ALARM is install-time on API 31-32 (auto-granted) but became
         user-revocable on API 33+. Cap it to 32 so we don't depend on the user flipping
         a Special App Access toggle on newer devices. -->
    <uses-permission
        android:name="android.permission.SCHEDULE_EXACT_ALARM"
        android:maxSdkVersion="32" />
    <!-- USE_EXACT_ALARM (API 33+) is install-time and auto-granted for apps whose core
         function is alarms/reminders — that's us. canScheduleExactAlarms() returns true
         once this is declared, so setExactAndAllowWhileIdle works without user action. -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".DoneBotApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DoneBot">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.DoneBot"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".ui.overlay.OverlayService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="alarm_overlay" />
        </service>

        <service
            android:name=".data.notification.NotificationService"
            android:foregroundServiceType="specialUse"
            android:exported="false">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="alarm_overlay" />
        </service>

        <receiver
            android:name=".data.alarm.AlarmFireReceiver"
            android:exported="false" />

        <!-- Disable androidx.startup's auto-init of WorkManager so DoneBotApplication's
             Configuration.Provider can take over and supply the HiltWorkerFactory.
             Without this, the default factory tries to instantiate workers via
             reflection and SyncWorker / FetchTasksWorker (which need TaskRepository
             injected) silently fail to construct — enqueue logs appear but doWork
             never runs. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>
    </application>

</manifest>
